<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App identity -->
    <key>CFBundleDisplayName</key>
    <string>Komet</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>MinimumOSVersion</key>
    <string>16.0</string>

    <!-- URL schemes -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>komet</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>komet</string>
                <string>max</string>
            </array>
        </dict>
    </array>

    <!-- Associated domains (Universal Links) -->
    <!-- Enable in Signing &amp; Capabilities → Associated Domains:
         applinks:max.ru
         applinks:vk.com  (if needed) -->

    <!-- Privacy usage strings (required for App Store) -->
    <key>NSCameraUsageDescription</key>
    <string>Komet uses the camera to scan QR codes for login and to take photos for messages.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Komet accesses your photo library to send photos and videos in chats.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Komet uses the microphone to record voice messages.</string>
    <key>NSFaceIDUsageDescription</key>
    <string>Komet uses Face ID to protect access to your chats.</string>
    <key>NSContactsUsageDescription</key>
    <string>Komet can sync your contacts to help you find people on MAX Messenger.</string>

    <!-- Push notifications -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
        <string>audio</string>
    </array>

    <!-- App Transport Security — allow custom TLS to api.oneme.ru -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>api.oneme.ru</key>
            <dict>
                <!-- Raw TLS TCP on port 443; not HTTP — disable ATS for this host -->
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <false/>
                <key>NSExceptionRequiresForwardSecrecy</key>
                <false/>
            </dict>
            <key>oneme.ru</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <false/>
            </dict>
        </dict>
    </dict>

    <!-- Orientation -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Status bar -->
    <key>UIStatusBarHidden</key>
    <false/>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>

    <!-- Launch screen -->
    <key>UILaunchScreen</key>
    <dict/>
</dict>
</plist>
